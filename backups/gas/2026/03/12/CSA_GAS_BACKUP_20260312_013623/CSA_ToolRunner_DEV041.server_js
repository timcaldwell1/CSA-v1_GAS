// ------------------------------------------------------------
// Ingest — Dry Run
// ------------------------------------------------------------

function RUN_DEV053_Ingest_Batch_DryRun() {
  var prefix = CSA_DEV053__activePrefix_();
  return CSA_DEV053_RunLaneIngest_Batch_DryRun_(prefix);
}


// ------------------------------------------------------------
// Ingest — Commit
// ------------------------------------------------------------

function RUN_DEV053_Ingest_Batch_Commit() {
  var prefix = CSA_DEV053__activePrefix_();
  return CSA_DEV053_RunLaneIngest_Batch_Commit_(prefix);
}


// ------------------------------------------------------------
// Status
// ------------------------------------------------------------

function RUN_DEV053_Status() {
  var prefix = CSA_DEV053__activePrefix_();
  return RUN_DEV053_Status__lane(prefix);
}


// ------------------------------------------------------------
// End-to-End
// ------------------------------------------------------------

function RUN_DEV053_E2E_CoP() {

  var prefix = CSA_DEV053__activePrefix_();
  Logger.log('[DEV053][E2E] START prefix=%s', prefix);

  var pre = RUN_DEV053_Status();

  RUN_DEV053_CoP_BuildQueue();
  RUN_DEV053_CoP_FreezeQueue();
  RUN_DEV053_ResetCursor();

  var mid = RUN_DEV053_Status();

  RUN_DEV053_Ingest_Batch_Commit();

  var post = RUN_DEV053_Status();

  Logger.log('[DEV053][E2E] DONE prefix=%s', prefix);

  return {
    ok: true,
    prefix: prefix,
    pre: pre,
    mid: mid,
    post: post
  };
}



/* ============================================================
   DEV056 — Observability Completion (Audit + Error)
============================================================ */

function RUN_DEV056_Migrate_AuditLog_CurrentPrefix() {
  return CSA_DEV056_Migrate_AuditLog_Sheet_To_V2_();
}


function RUN_DEV056_SmokeTest_AuditAndErrorLogs() {

  var props = PropertiesService.getScriptProperties().getProperties();
  var prefix = String(props.CSA_SHEET_PREFIX || 'test5').trim();

  if (prefix && prefix.slice(-1) === '_') {
    prefix = prefix.slice(0, -1);
  }

  var migration = CSA_DEV056_Migrate_AuditLog_Sheet_To_V2_(prefix);

  var audit = CSA_LogAudit_(
    'TOOLRUNNER_INVOKE',
    'SUCCESS',
    'RUN_DEV056_SmokeTest_AuditAndErrorLogs',
    {
      run_id: '',
      message: 'DEV056 smoke test (audit)',
      prefix: prefix
    }
  );

  CSA_LogError_(
    new Error('DEV056 smoke test (error_log)'),
    'RUN_DEV056_SmokeTest_AuditAndErrorLogs'
  );

  return {
    ok: true,
    prefix: prefix,
    migration: migration,
    audit: audit,
    note: 'Smoke test appended 1 audit row + 1 error row.'
  };
}



/* ============================================================
   DEV057 — Apps Script History (Best-Effort)
============================================================ */

function RUN_HISTORY_ShowProjectHistoryLink_DEV057() {

  var scriptId = ScriptApp.getScriptId();
  var url = 'https://script.google.com/home/projects/' + encodeURIComponent(scriptId) + '/edit';

  Logger.log('[DEV057][HISTORY] Project link: %s', url);

  return {
    ok: true,
    script_id: scriptId,
    editor_url: url
  };
}



/* ============================================================
   DEV057 — Backup → GitHub Push
============================================================ */

function RUN_DEV057_Backup_Then_Push_To_GitHub() {

  var t0 = new Date();
  Logger.log('[DEV057][BACKUP+PUSH] Starting at %s', t0.toISOString());

  CSA_Backup_GAS_Source_OnDemand();

  var pushResult = CSA_GitHub_Push_Latest_GAS_Snapshot_To_GitHub_DEV049_();

  var t1 = new Date();
  var ms = t1.getTime() - t0.getTime();

  Logger.log('[DEV057][BACKUP+PUSH] Completed in %sms', ms);

  return {
    ok: true,
    duration_ms: ms,
    push_result: pushResult
  };
}



/* ============================================================
   DEV064 — Cursor + Batch Diagnostic
   Non-mutating — safe to run anytime
============================================================ */

function RUN_DEV064_Debug_Cursor_State() {

  var props = PropertiesService.getScriptProperties().getProperties();

  var snapshot = {
    timestamp: new Date().toISOString(),

    CSA_ENV: props.CSA_ENV,
    CSA_SHEET_PREFIX: props.CSA_SHEET_PREFIX,
    CSA_INGEST_PREFIX: props.CSA_INGEST_PREFIX,

    CSA_DEV053_BATCH_SIZE: props.CSA_DEV053_BATCH_SIZE,
    CSA_DEV053_CURSOR_test5: props.CSA_DEV053_CURSOR_test5,
    CSA_DEV053_CURSOR_test6: props.CSA_DEV053_CURSOR_test6
  };

  Logger.log('[DEV064][CURSOR_DEBUG] %s', JSON.stringify(snapshot));

  return {
    ok: true,
    debug: snapshot
  };
}