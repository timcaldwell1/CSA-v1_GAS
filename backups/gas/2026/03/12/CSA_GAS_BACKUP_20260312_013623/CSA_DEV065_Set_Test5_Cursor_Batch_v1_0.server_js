function RUN_DEV065_Set_Test5_Cursor2_Batch20() {
  var props = PropertiesService.getScriptProperties();
  var env = String(props.getProperty('CSA_ENV') || '').toUpperCase();

  if (env === 'PROD') {
    throw new Error('DEV065: Refused CSA_ENV=PROD.');
  }

  props.setProperty('CSA_DEV053_CURSOR_test5', '2');
  props.setProperty('CSA_DEV053_BATCH_SIZE', '20');

  var out = {
    ok: true,
    timestamp_mst: Utilities.formatDate(new Date(), 'America/Phoenix', 'yyyy-MM-dd HH:mm:ss') + ' MST',
    CSA_ENV: props.getProperty('CSA_ENV'),
    CSA_INGEST_PREFIX: props.getProperty('CSA_INGEST_PREFIX'),
    CSA_DEV053_CURSOR_test5: props.getProperty('CSA_DEV053_CURSOR_test5'),
    CSA_DEV053_BATCH_SIZE: props.getProperty('CSA_DEV053_BATCH_SIZE')
  };

  Logger.log('[DEV065][SETTER] %s', JSON.stringify(out));
  return out;
}