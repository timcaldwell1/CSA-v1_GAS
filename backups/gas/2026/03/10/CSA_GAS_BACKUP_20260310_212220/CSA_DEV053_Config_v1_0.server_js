function CSA_DEV053_GetWebAppPrefix_() {
  const props = PropertiesService.getScriptProperties();
  return props.getProperty('CSA_WEBAPP_PREFIX') || 'test3';
}

function CSA_DEV053_GetIngestPrefix_() {
  const props = PropertiesService.getScriptProperties();
  return props.getProperty('CSA_INGEST_PREFIX') || 'test6';
}

function CSA_DEV053_AssertDevEnv_() {
  const env = PropertiesService.getScriptProperties().getProperty('CSA_ENV');
  if (env === 'PROD') {
    throw new Error('CSA_DEV053: PROD execution blocked.');
  }
  if (env !== 'DEV') {
    throw new Error('CSA_DEV053: ENV must be DEV.');
  }
}