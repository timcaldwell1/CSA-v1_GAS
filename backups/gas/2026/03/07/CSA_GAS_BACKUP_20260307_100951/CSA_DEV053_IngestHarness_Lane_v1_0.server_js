/**
 * ============================================================================
 * File Name: CSA_DEV053_IngestHarness_Lane_v1_2_DEV055.gs
 * Title: DEV053 — Lane Ingest Harness (Batched) + Queue Freeze + Append-Only Writes
 * Product: CSA_v1.0 — Church Safety Alerts
 * Artifact Namespace: CSA_v1.1
 * Version: v1.2 (DEV055) + DEV058 Patch (audit/error contract alignment)
 * Status: WORKING — DEV058 QA Enablement (test5 lane) + Logging Drift Correction
 *
 * Thread Lineage:
 * DEV046 (RawPubDate contract: verbatim + optional; no normalization) →
 * DEV048 (Harness patterns, safe hooks, keyword matching model, risk label) →
 * DEV053 (CoP queue builder + lane ingest + cursoring) →
 * DEV055 (prefix posture discipline + stability checkpoints) →
 * DEV056 (audit logging schema + migration) →
 * DEV058 (QA runner + logging drift exercise)
 *
 * Purpose:
 * - Execute batched ingestion for a specific campus lane (prefix) such as test5_ or test6_.
 * - Read frozen queue rows from <prefix>poc_ingest_queue
 * - Match keywords from <prefix>keyword_defs
 * - Write results append-only into:
 *     <prefix>incident_data (included)
 *     <prefix>discarded_events (discarded)
 * - Emit audit start/end records for observability and run correlation.
 *
 * Key Behaviors (What this file actually does):
 * 1) Environment Guardrails
 *    - Refuses CSA_ENV=PROD
 *    - Requires DEV posture; returns refusal error object for non-DEV (PoC-safe)
 *
 * 2) Prefix / Lane Handling
 *    - Accepts prefix input and/or Script Property CSA_INGEST_PREFIX
 *    - Normalizes prefix (test5 vs test5_) and enforces allowed prefixes for safety
 *    - Writes campus prefix into logs as "test5" (no underscore) for readability/consistency
 *
 * 3) Cursoring + Batch Processing
 *    - Maintains per-lane cursor in Script Properties: CSA_DEV053_CURSOR_<lane>
 *    - Processes up to CSA_DEV053_BATCH_SIZE rows per run
 *    - Advances cursor after processing; append-only; no rewriting prior rows
 *
 * 4) Queue Contract (Input Surface)
 *    - Requires queue headers (minimum contract):
 *      incident_id, incident_type, description, location, RawPubDate
 *    - Reads rows via getDisplayValues to avoid unintended date coercion
 *    - RawPubDate is treated as:
 *      - Optional (may be blank)
 *      - Verbatim (never parsed/normalized)
 *
 * 5) Keyword/Risk Model
 *    - Loads keyword_defs (requires headers keyword, taxonomy_class, active)
 *    - Signal vs Negation behavior:
 *      - No SIGNAL → discard (reason NO_SIGNAL or NEGATION_NO_SIGNAL)
 *      - SIGNAL present → include (SIGNAL wins even if NEGATION also matches)
 *    - Risk computation (PoC):
 *      risk_level = min(10, 5 * SIGNAL_count)
 *      risk_label derived via CSA_DEV048_RiskLabel_ when available
 *
 * 6) Output Writers (Append-only)
 *    - Included rows appended to <prefix>incident_data using header-aware builders when present:
 *      CSA_DEV048_BuildIncidentRow_
 *    - Discarded rows appended to <prefix>discarded_events using:
 *      CSA_DEV048_BuildDiscardRow_
 *    - Supports dry-run mode where no sheet writes occur (still audits)
 *
 * 7) Observability / Logging
 *    - Emits run start/end audit events (INGEST_RUN_START / INGEST_RUN_END)
 *    - DEV058 patch routes audit writes through CSA_LogAudit_ when present to avoid:
 *        - UTC/Zulu timestamps in timestamp_mst
 *        - run_id mistakenly written into prefix column
 *        - missing user/run_id population
 *    - Error handling is fail-open at row scope:
 *      - Row exceptions increment error count and attempt CSA_LogError_
 *      - Legacy fallback appends a best-effort error row if error logger unavailable
 *
 * DEV058 Patch Notes (Why this changed during DEV058):
 * - timestamp_mst must be "YYYY-MM-DD HH:mm:ss MST" (Phoenix local), not ISO Zulu.
 *   Preferred: CSA_DEV041_FormatMST_(new Date()).
 * - prefix column in audit/error logs must be the campus prefix (e.g., "test5").
 * - user and run_id columns must be populated consistently for correlation.
 * - Audit/logging issues must not prevent pipeline execution (PoC-ready fail-open).
 *
 * Inputs / Dependencies:
 * - Script Properties: CSA_ENV, CSA_SHEET_PREFIX, CSA_INGEST_PREFIX, CSA_SPREADSHEET_ID,
 *   CSA_DEV053_BATCH_SIZE, CSA_DEV053_CURSOR_<lane>
 * - Optional functions used when present:
 *   CSA_DEV048_* builders/normalizers, CSA_LogAudit_, CSA_LogError_,
 *   CSA_DEV041_FormatMST_, CSA_DEV053_ReadHeader_, CSA_DEV053_IndexHeader_
 *
 * Outputs:
 * - <prefix>incident_data (append-only)
 * - <prefix>discarded_events (append-only)
 * - <prefix>audit_log (append-only, via CSA_LogAudit_ when available)
 * - <prefix>error_log (append-only, via CSA_LogError_ when available)
 *
 * Safety / Constraints:
 * - Append-only; never rewrites existing business rows
 * - Refuses PROD; designed for DEV/QA harness runs
 *
 * Last Updated (MST): 2026-03-03
 * Authors: Tim Caldwell; DEV053-Author; DEV055-Author; DEV017-Author (G)
 * ============================================================================
 */

var CSA_DEV053_INGEST = {
  ALLOWED_PREFIXES: ['test5_', 'test6_'],
  MIN_BATCH_SIZE: 50,
  MAX_BATCH_SIZE: 1000
};

function CSA_DEV053__cursorKey_(prefixWithUnderscore) {
  var p = String(prefixWithUnderscore || '').replace(/_+$/g, '');
  return 'CSA_DEV053_CURSOR_' + p;
}

function CSA_DEV053__getBatchSize_() {
  var props = PropertiesService.getScriptProperties();
  var raw = String(props.getProperty('CSA_DEV053_BATCH_SIZE') || '500').trim();
  var n = parseInt(raw, 10);
  if (!isFinite(n)) n = 500;
  if (n < CSA_DEV053_INGEST.MIN_BATCH_SIZE) n = 500;
  if (n > CSA_DEV053_INGEST.MAX_BATCH_SIZE) n = CSA_DEV053_INGEST.MAX_BATCH_SIZE;
  return n;
}

function CSA_DEV053__getCursor_(prefixWithUnderscore) {
  var props = PropertiesService.getScriptProperties();
  var k = CSA_DEV053__cursorKey_(prefixWithUnderscore);
  var raw = String(props.getProperty(k) || '2').trim();
  var n = parseInt(raw, 10);
  if (!isFinite(n) || n < 2) n = 2;
  return n;
}

function CSA_DEV053__setCursor_(prefixWithUnderscore, nextRow) {
  var props = PropertiesService.getScriptProperties();
  var k = CSA_DEV053__cursorKey_(prefixWithUnderscore);
  props.setProperty(k, String(nextRow));
}

/**
 * Primary harness entrypoint.
 * Options: { prefix: "test5"|"test5_"|"test6"|"test6_", dry_run: "TRUE"|"FALSE" }
 */
function CSA_DEV053_RunLaneIngestHarness_(options) {

  options = options || {};
  var dryRun = String(options.dry_run).toUpperCase() === 'TRUE';

  var started = new Date();
  var runId = 'DEV053_' + started.getTime();

  var props = PropertiesService.getScriptProperties().getProperties();
  var env = String(props.CSA_ENV || '').toUpperCase();

  if (env === 'PROD') throw new Error('DEV053: Refused CSA_ENV=PROD.');
  if (env !== 'DEV') return { ok: false, run_id: runId, env: env, error: 'REFUSED_ENV_NOT_DEV' };

  var rawPrefix = String(options.prefix || props.CSA_INGEST_PREFIX || '').trim();
  if (!rawPrefix) return { ok: false, run_id: runId, env: env, error: 'MISSING_PREFIX' };

  var prefix = (typeof CSA_DEV048_NormalizeSheetPrefix_ === 'function')
    ? CSA_DEV048_NormalizeSheetPrefix_(rawPrefix)
    : (String(rawPrefix).replace(/_+$/g, '') + '_');

  if (CSA_DEV053_INGEST.ALLOWED_PREFIXES.indexOf(prefix) === -1) {
    return { ok: false, run_id: runId, env: env, prefix: prefix, error: 'REFUSED_PREFIX_NOT_ALLOWED' };
  }

  var prefixNoUnderscore = String(prefix).replace(/_+$/g, '');

  var ss = (typeof CSA_DEV048_OpenSpreadsheet_ === 'function')
    ? CSA_DEV048_OpenSpreadsheet_()
    : SpreadsheetApp.getActiveSpreadsheet();

  var shQueue = ss.getSheetByName(prefix + 'poc_ingest_queue');
  var shKw    = ss.getSheetByName(prefix + 'keyword_defs');
  var shInc   = ss.getSheetByName(prefix + 'incident_data');
  var shDisc  = ss.getSheetByName(prefix + 'discarded_events');
  var shAudit = ss.getSheetByName(prefix + 'audit_log');
  var shError = ss.getSheetByName(prefix + 'error_log');

  if (!shQueue || !shKw || !shInc || !shDisc) {
    throw new Error('DEV053: Missing required sheet for prefix ' + prefix);
  }

  // Canonical MST stamp: "YYYY-MM-DD HH:mm:ss MST" (no 'T', no 'Z')
  var tsMst = (typeof CSA_DEV041_FormatMST_ === 'function')
    ? CSA_DEV041_FormatMST_(new Date())
    : (Utilities.formatDate(new Date(), 'America/Phoenix', 'yyyy-MM-dd HH:mm:ss') + ' MST');

  // ---- RUN START AUDIT (canonical) ----
  if (typeof CSA_LogAudit_ === 'function') {
    CSA_LogAudit_(
      'INGEST_RUN_START',
      'SUCCESS',
      'CSA_DEV053_RunLaneIngestHarness_',
      {
        run_id: runId,
        env: env,
        prefix: prefixNoUnderscore,
        dry_run: dryRun,
        timestamp_mst: tsMst
      }
    );
  } else if (shAudit) {
    // Fallback: best-effort 10-col write
    shAudit.appendRow([
      Utilities.getUuid(),
      tsMst,
      'INGEST_RUN_START',
      'SUCCESS',
      'CSA_DEV053_RunLaneIngestHarness_',
      env,
      prefixNoUnderscore,
      'SYSTEM',
      runId,
      '{}'
    ]);
  }

  var batchSize = CSA_DEV053__getBatchSize_();
  var cursorRow = CSA_DEV053__getCursor_(prefix);
  var lastRow = shQueue.getLastRow();

  if (lastRow < 2 || cursorRow > lastRow) {
    if (typeof CSA_LogAudit_ === 'function') {
      CSA_LogAudit_(
        'INGEST_RUN_END',
        'SUCCESS',
        'CSA_DEV053_RunLaneIngestHarness_',
        {
          run_id: runId,
          env: env,
          prefix: prefixNoUnderscore,
          dry_run: dryRun,
          note: 'NO_WORK',
          cursor_row: cursorRow,
          last_row: lastRow
        }
      );
    } else if (shAudit) {
      shAudit.appendRow([
        Utilities.getUuid(),
        tsMst,
        'INGEST_RUN_END',
        'SUCCESS',
        'CSA_DEV053_RunLaneIngestHarness_',
        env,
        prefixNoUnderscore,
        'SYSTEM',
        runId,
        '{"note":"NO_WORK"}'
      ]);
    }
    return { ok: true, run_id: runId, prefix: prefix, done: true };
  }

  // Queue header → index
  var qHdr = (typeof CSA_DEV053_ReadHeader_ === 'function')
    ? CSA_DEV053_ReadHeader_(shQueue)
    : shQueue.getRange(1, 1, 1, shQueue.getLastColumn()).getDisplayValues()[0].map(function(x){ return String(x||'').trim(); });

  var qIdx = (typeof CSA_DEV053_IndexHeader_ === 'function')
    ? CSA_DEV053_IndexHeader_(qHdr)
    : (function(h){ var m={}; for (var i=0;i<h.length;i++) m[String(h[i]||'').trim()] = i; return m; })(qHdr);

  function reqIdx(name) {
    var i = qIdx[name];
    if (i === undefined || i === null || i < 0) throw new Error('DEV053: Missing required queue header: ' + name);
    return i;
  }

  var idxIncidentId   = reqIdx('incident_id');
  var idxIncidentType = reqIdx('incident_type');
  var idxDesc         = reqIdx('description');
  var idxLocation     = reqIdx('location');
  var idxRawPubDate   = reqIdx('RawPubDate');

  // Keyword defs header → index
  var kwHdr = (typeof CSA_DEV053_ReadHeader_ === 'function')
    ? CSA_DEV053_ReadHeader_(shKw)
    : shKw.getRange(1, 1, 1, shKw.getLastColumn()).getDisplayValues()[0].map(function(x){ return String(x||'').trim(); });

  var kwMap = (typeof CSA_DEV053_IndexHeader_ === 'function')
    ? CSA_DEV053_IndexHeader_(kwHdr)
    : (function(h){ var m={}; for (var i=0;i<h.length;i++) m[String(h[i]||'').trim()] = i; return m; })(kwHdr);

  if (kwMap.keyword == null || kwMap.taxonomy_class == null || kwMap.active == null) {
    throw new Error('DEV053: keyword_defs missing required headers: keyword, taxonomy_class, active');
  }

  var matchers = (typeof CSA_DEV048_LoadKeywordDefs_ === 'function')
    ? CSA_DEV048_LoadKeywordDefs_(shKw, kwHdr, { keyword: kwMap.keyword, taxonomy_class: kwMap.taxonomy_class, active: kwMap.active })
    : { signal: [], negation: [] };

  // Target headers
  var incHdr = (typeof CSA_DEV053_ReadHeader_ === 'function')
    ? CSA_DEV053_ReadHeader_(shInc)
    : shInc.getRange(1, 1, 1, shInc.getLastColumn()).getDisplayValues()[0].map(function(x){ return String(x||'').trim(); });

  var discHdr = (typeof CSA_DEV053_ReadHeader_ === 'function')
    ? CSA_DEV053_ReadHeader_(shDisc)
    : shDisc.getRange(1, 1, 1, shDisc.getLastColumn()).getDisplayValues()[0].map(function(x){ return String(x||'').trim(); });

  var take = Math.min(batchSize, lastRow - cursorRow + 1);
  var lastCol = Math.max(1, shQueue.getLastColumn());
  var batch = shQueue.getRange(cursorRow, 1, take, lastCol).getDisplayValues();

  var includeCount = 0, discardCount = 0, errorCount = 0;
  var includeRows = [];
  var discardRows = [];

  var campusDefault = (typeof CSA_DEV048_GetCampusDefault_ === 'function')
    ? CSA_DEV048_GetCampusDefault_(props)
    : (String(props.CSA_CAMPUS_NAME || '*').trim() || '*');

  for (var r = 0; r < batch.length; r++) {
    try {
      var row = batch[r];

      var incidentId = String(row[idxIncidentId] || '').trim();
      if (!incidentId) continue;

      var incidentType = String(row[idxIncidentType] || '');
      var description  = String(row[idxDesc] || '');
      var location     = String(row[idxLocation] || '');
      var rawPubDate   = String(row[idxRawPubDate] || ''); // preserve verbatim (may be blank)

      var norm = (typeof CSA_DEV048_NormalizeText_ === 'function')
        ? CSA_DEV048_NormalizeText_(incidentType + ' ' + description)
        : String((incidentType + ' ' + description) || '').toLowerCase();

      var signals = (typeof CSA_DEV048_FindMatches_ === 'function')
        ? CSA_DEV048_FindMatches_(norm, matchers.signal || [])
        : [];

      var negs = (typeof CSA_DEV048_FindMatches_ === 'function')
        ? CSA_DEV048_FindMatches_(norm, matchers.negation || [])
        : [];

      if (!signals || signals.length === 0) {
        var reason = (negs && negs.length > 0) ? 'NEGATION_NO_SIGNAL' : 'NO_SIGNAL';
        var trigger = (negs && negs.length > 0) ? String(negs[0]) : '';

        var discObj = {
          incident_id: incidentId,
          stage: 'KEYWORD',
          reason_code: reason,
          trigger: trigger,
          campus: campusDefault,
          timestamp: tsMst
        };

        var discRow = (typeof CSA_DEV048_BuildDiscardRow_ === 'function')
          ? CSA_DEV048_BuildDiscardRow_(discHdr, null, discObj)
          : [incidentId, 'KEYWORD', reason, trigger, campusDefault, tsMst];

        discardRows.push(discRow);
        discardCount++;
        continue;
      }

      var riskLevel = Math.min(10, 5 * signals.length);
      var riskLabel = (typeof CSA_DEV048_RiskLabel_ === 'function') ? CSA_DEV048_RiskLabel_(riskLevel) : '';

      var incObj = {
        incident_id: incidentId,
        incident_type: incidentType,
        description: description,
        matched_keywords: (signals || []).join(','),
        risk_level: riskLevel,
        risk_label: riskLabel,
        campus: campusDefault,
        timestamp: tsMst,
        RawPubDate: rawPubDate,
        risk_model_version: 'PoC_5x_CAP10_v1',
        location: location
      };

      var incRow = (typeof CSA_DEV048_BuildIncidentRow_ === 'function')
        ? CSA_DEV048_BuildIncidentRow_(incHdr, null, incObj)
        : [incidentId, incidentType, description, (signals||[]).join(','), riskLevel, riskLabel, campusDefault, tsMst, rawPubDate, 'PoC_5x_CAP10_v1'];

      includeRows.push(incRow);
      includeCount++;

    } catch (err) {
      errorCount++;

      if (typeof CSA_LogError_ === 'function') {
        CSA_LogError_(err, 'CSA_DEV053_RunLaneIngestHarness_', {
          incident_id: '',
          details: { row_index: r, cursor_row: cursorRow, prefix: prefixNoUnderscore, run_id: runId },
          severity: 'ERROR',
          source: 'DEV053',
          function_name: 'CSA_DEV053_RunLaneIngestHarness_',
          message: 'Row processing error',
          domain: 'INGEST',
          stage: 'ROW',
          outcome: 'ROW_EXCEPTION',
          request_id: runId
        });
      } else if (shError) {
        shError.appendRow([
          Utilities.getUuid(),
          tsMst,
          'ROW_EXCEPTION',
          '',
          (err && err.message ? err.message : String(err)),
          '',
          '',
          '',
          'ERROR',
          env,
          'DEV053',
          'CSA_DEV053_RunLaneIngestHarness_',
          'Row processing error',
          '',
          '',
          '',
          '',
          '',
          '',
          runId
        ]);
      }
    }
  }

  if (!dryRun) {
    if (discardRows.length > 0) {
      var discStart = shDisc.getLastRow() + 1;
      shDisc.getRange(discStart, 1, discardRows.length, discHdr.length).setValues(discardRows);
    }
    if (includeRows.length > 0) {
      var incStart = shInc.getLastRow() + 1;
      shInc.getRange(incStart, 1, includeRows.length, incHdr.length).setValues(includeRows);
    }
  }

  var nextCursor = cursorRow + take;
  CSA_DEV053__setCursor_(prefix, nextCursor);

  if (typeof CSA_LogAudit_ === 'function') {
    CSA_LogAudit_(
      'INGEST_RUN_END',
      'SUCCESS',
      'CSA_DEV053_RunLaneIngestHarness_',
      {
        run_id: runId,
        env: env,
        prefix: prefixNoUnderscore,
        dry_run: dryRun,
        cursor_start: cursorRow,
        cursor_next: nextCursor,
        batch_take: take,
        included: includeCount,
        discarded: discardCount,
        errors: errorCount
      }
    );
  } else if (shAudit) {
    shAudit.appendRow([
      Utilities.getUuid(),
      tsMst,
      'INGEST_RUN_END',
      'SUCCESS',
      'CSA_DEV053_RunLaneIngestHarness_',
      env,
      prefixNoUnderscore,
      'SYSTEM',
      runId,
      '{"included":' + includeCount + ',"discarded":' + discardCount + ',"errors":' + errorCount + '}'
    ]);
  }

  return {
    ok: true,
    run_id: runId,
    prefix: prefix,
    included: includeCount,
    discarded: discardCount,
    errors: errorCount,
    dry_run: dryRun
  };
}

function CSA_DEV053_RunLaneIngest_Batch_DryRun_(lanePrefix) {
  return CSA_DEV053_RunLaneIngestHarness_({ prefix: lanePrefix, dry_run: 'TRUE' });
}

function CSA_DEV053_RunLaneIngest_Batch_Commit_(lanePrefix) {
  return CSA_DEV053_RunLaneIngestHarness_({ prefix: lanePrefix, dry_run: 'FALSE' });
}